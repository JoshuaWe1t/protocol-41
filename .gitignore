.AppleDouble
.LSOverride
Icon
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Папки внешних редакторов кода (если ты используешь VS Code, Rider и т.д.)
.vscode/
.idea/
*.sln
*.csproj
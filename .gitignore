# Специфичная папка Godot 4 (КРИТИЧЕСКИ ВАЖНО ИГНОРИРОВАТЬ!)
.godot/
/android/

# Папки для готовых сборок игры (чтобы не пушить тяжелые .exe или .apk файлы)
export/
export_presets.cfg
build/
builds/

